# Cloudflare R2 配置
# 复制此文件为 .env 并填入实际值

# Cloudflare 账号 ID（在 R2 概览页右侧能找到）
R2_ACCOUNT_ID=

# R2 API Token（在 Manage R2 API Tokens 页面创建，权限选 Admin Read+Write）
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 Bucket 名称
R2_BUCKET=

# R2 公开访问域名前缀
# 格式: https://<bucket>.<account>.r2.dev
# 在 R2 Bucket Settings → R2.dev domain 获取
R2_PUBLIC_URL=
